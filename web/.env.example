# In dev, leave blank — Vite proxies /api to VITE_API_PROXY_TARGET (default :8000).
# In prod (split deploy), set this to your FastAPI origin, e.g. https://api.roguelearn.app
VITE_API_BASE_URL=

# Override the dev proxy target (default http://localhost:8000) if your API runs elsewhere.
# VITE_API_PROXY_TARGET=http://localhost:8000
